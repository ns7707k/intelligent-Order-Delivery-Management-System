# ODMS Backend Environment Variables

# Flask Configuration
FLASK_CONFIG=development
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=postgresql://postgres.<project-ref>:<url-encoded-password>@aws-1-eu-west-2.pooler.supabase.com:6543/postgres?sslmode=require
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/odms_test

# Note:
# If your password contains special characters (like @, :, /, #), URL-encode it.
# Example: Azam@12345fyp -> Azam%4012345fyp

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# OR-Tools
ORTOOLS_TIME_LIMIT_SECONDS=30

# Voice Settings
VOICE_CONFIDENCE_THRESHOLD=0.8

# Server
PORT=5000
